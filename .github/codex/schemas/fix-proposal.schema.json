{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vectology-cloud-team/namma-rogue-agent/.github/codex/schemas/fix-proposal.schema.json",
  "title": "NaMMA AI Fix Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_id",
    "repository",
    "pull_request_number",
    "base_sha",
    "head_sha",
    "source_review_run_id",
    "source_review_artifact_id",
    "reviewed_at",
    "generator",
    "summary",
    "findings_addressed",
    "changes",
    "tests_recommended",
    "risks",
    "human_approval_required"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "proposal_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "pull_request_number": {
      "type": "integer",
      "minimum": 1
    },
    "base_sha": {
      "$ref": "#/$defs/full_sha"
    },
    "head_sha": {
      "$ref": "#/$defs/full_sha"
    },
    "source_review_run_id": {
      "type": "integer",
      "minimum": 1
    },
    "source_review_artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "reasoning_effort",
        "policy_version"
      ],
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "reasoning_effort": {
          "type": "string",
          "minLength": 1
        },
        "policy_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings_addressed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "severity",
          "category"
        ],
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "category": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "operation",
          "original_blob_sha",
          "patch",
          "rationale"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(^|/)\\.\\.(/|$)).+$"
          },
          "operation": {
            "const": "modify"
          },
          "original_blob_sha": {
            "$ref": "#/$defs/full_sha"
          },
          "patch": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20000,
            "not": {
              "anyOf": [
                {
                  "pattern": "GIT binary patch|Binary files |new file mode |deleted file mode |old mode |new mode |rename from |rename to |similarity index |dissimilarity index "
                },
                {
                  "pattern": "(^|\\n)(--- |\\+\\+\\+ )/dev/null($|\\t|\\n)"
                },
                {
                  "pattern": "(^|\\n)diff --git .*\\\""
                },
                {
                  "pattern": "(^|\\n)(--- |\\+\\+\\+ )\\\""
                }
              ]
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tests_recommended": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "human_approval_required": {
      "const": true
    }
  },
  "$defs": {
    "full_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    }
  }
}
