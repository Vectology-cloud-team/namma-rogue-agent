  "$defs": {
    "full_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*[\\u0000-\\u001F\\u007F\\u061C\\u200E\\u200F\\u202A-\\u202E\\u2066-\\u2069])(?!.*(^|/)\\.\\.($|/))(?!.*(^|/)\\.git($|/))[^\\\\]+$"
    },
    "path_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repo_path"
      },
      "uniqueItems": true
    },
    "test_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "test_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_id",
        "requested",
        "executed",
        "status",
        "exit_code",
        "duration_ms",
        "log_excerpt"
      ],
      "properties": {
        "test_id": {
          "$ref": "#/$defs/test_id"
        },
        "requested": {
          "type": "boolean"
        },
        "executed": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "SKIPPED",
            "INFRA_ERROR"
          ]
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "log_excerpt": {
          "type": "string",
          "maxLength": 4000
        }
      }
    },
    "target_blob_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "expected_blob_sha",
        "actual_blob_sha",
        "file_type",
        "mode",
        "size",
        "status"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/repo_path"
        },
        "expected_blob_sha": {
          "$ref": "#/$defs/full_sha"
        },
        "actual_blob_sha": {
          "$ref": "#/$defs/full_sha"
        },
        "file_type": {
          "const": "blob"
        },
        "mode": {
          "type": "string",
          "enum": [
            "100644",
            "100755"
          ]
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "const": "PASS"
        }
      }
    },
    "patch_metadata_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "message",
        "patch_bytes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "message": {
          "type": "string",
          "maxLength": 2000
        },
        "patch_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "check_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "message"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "SKIPPED"
          ]
        },
        "message": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "artifact_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_name",
        "workflow_run_id",
        "workflow_name",
        "repository",
        "pull_request_number",
        "head_sha"
      ],
      "properties": {
        "artifact_id": {
          "type": "integer",
          "minimum": 1
        },
        "artifact_name": {
          "type": "string",
          "minLength": 1
        },
        "workflow_run_id": {
          "type": "integer",
          "minimum": 1
        },
        "workflow_name": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "pull_request_number": {
          "type": "integer",
          "minimum": 1
        },
        "head_sha": {
          "$ref": "#/$defs/full_sha"
        }
      }
    }
  }
}
