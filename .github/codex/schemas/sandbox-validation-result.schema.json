{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vectology-cloud-team/namma-rogue-agent/.github/codex/schemas/sandbox-validation-result.schema.json",
  "title": "NaMMA AI Sandbox Validation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "validation_id",
    "phase",
    "repository",
    "pull_request_number",
    "base_sha",
    "head_sha",
    "proposal_id",
    "proposal_hash",
    "approval_id",
    "approval_record_hash",
    "approved_by",
    "approved_by_repository_permission",
    "approved_by_repository_role",
    "validation_request_actor",
    "validation_request_actor_repository_permission",
    "validation_request_actor_repository_role",
    "live_labels",
    "proposal_artifact",
    "approval_artifact",
    "schema_versions",
    "policy_hash",
    "test_plan_hash",
    "started_at",
    "completed_at",
    "status",
    "failure_class",
    "failure_code",
    "patch_check",
    "patch_apply",
    "expected_files",
    "actual_changed_files",
    "protected_path_check",
    "blob_sha_check",
    "target_blob_checks",
    "patch_metadata_check",
    "tests_requested",
    "tests_executed",
    "test_results",
    "changed_files_match_expected",
    "persistent_repository_modified",
    "sandbox_worktree_modified",
    "sandbox_checkout_performed",
    "patch_check_performed",
    "patch_applied",
    "test_execution_performed",
    "commit_created",
    "push_performed",
    "merge_performed",
    "sandbox_destroyed"
  ],
  "properties": {
    "schema_version": {
      "const": "sandbox-validation-result-v1"
    },
    "validation_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "phase": {
      "type": "string",
      "enum": [
        "PREFLIGHT",
        "SANDBOX",
        "SANDBOX_APPLY"
      ]
    },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "pull_request_number": {
      "type": "integer",
      "minimum": 1
    },
    "base_sha": {
      "$ref": "#/$defs/full_sha"
    },
    "head_sha": {
      "$ref": "#/$defs/full_sha"
    },
    "proposal_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "proposal_hash": {
      "$ref": "#/$defs/sha256"
    },
    "approval_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "approval_record_hash": {
      "$ref": "#/$defs/sha256"
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "approved_by_repository_permission": {
      "type": "string",
      "enum": [
        "admin",
        "maintain"
      ]
    },
    "approved_by_repository_role": {
      "type": [
        "string",
        "null"
      ]
    },
    "validation_request_actor": {
      "type": "string",
      "minLength": 1
    },
    "validation_request_actor_repository_permission": {
      "type": "string",
      "enum": [
        "admin",
        "maintain"
      ]
    },
    "validation_request_actor_repository_role": {
      "type": [
        "string",
        "null"
      ]
    },
    "live_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "proposal_artifact": {
      "$ref": "#/$defs/artifact_provenance"
    },
    "approval_artifact": {
      "$ref": "#/$defs/artifact_provenance"
    },
    "schema_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proposal",
        "approval",
        "validation_result"
      ],
      "properties": {
        "proposal": {
          "type": "string",
          "minLength": 1
        },
        "approval": {
          "type": "string",
          "minLength": 1
        },
        "validation_result": {
          "const": "sandbox-validation-result-v1"
        }
      }
    },
    "policy_hash": {
      "$ref": "#/$defs/sha256"
    },
    "test_plan_hash": {
      "$ref": "#/$defs/sha256"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "APPLY_PASSED",
        "PRECHECK_PASSED",
        "PATCH_REJECTED",
        "TEST_FAILED",
        "STALE",
        "FATAL",
        "INFRA_ERROR"
      ]
    },
    "failure_class": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "PATCH_REJECTED",
        "TEST_FAILED",
        "STALE",
        "FATAL",
        "INFRA_ERROR",
        null
      ]
    },
    "failure_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "patch_check": {
      "$ref": "#/$defs/check_result"
    },
    "patch_apply": {
      "$ref": "#/$defs/check_result"
    },
    "expected_files": {
      "$ref": "#/$defs/path_array"
    },
    "actual_changed_files": {
      "$ref": "#/$defs/path_array"
    },
    "protected_path_check": {
      "$ref": "#/$defs/check_result"
    },
    "blob_sha_check": {
      "$ref": "#/$defs/check_result"
    },
    "target_blob_checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/target_blob_check"
      }
    },
    "patch_metadata_check": {
      "$ref": "#/$defs/patch_metadata_check"
    },
    "tests_requested": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/test_evidence"
          },
          {
            "properties": {
              "requested": {
                "const": true
              }
            }
          }
        ]
      }
    },
    "tests_executed": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/test_evidence"
          },
          {
            "properties": {
              "executed": {
                "const": true
              }
            }
          }
        ]
      }
    },
    "test_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/test_evidence"
      }
    },
    "changed_files_match_expected": {
      "type": "boolean"
    },
    "persistent_repository_modified": {
      "const": false
    },
    "sandbox_worktree_modified": {
      "type": "boolean"
    },
    "sandbox_checkout_performed": {
      "type": "boolean"
    },
    "patch_check_performed": {
      "type": "boolean"
    },
    "patch_applied": {
      "type": "boolean"
    },
    "test_execution_performed": {
      "type": "boolean"
    },
    "commit_created": {
      "const": false
    },
    "push_performed": {
      "const": false
    },
    "merge_performed": {
      "const": false
    },
    "sandbox_destroyed": {
      "type": "boolean"
    },
    "apply_request_actor": {
      "type": "string",
      "minLength": 1
    },
    "apply_request_actor_repository_permission": {
      "type": "string",
      "enum": [
        "admin",
        "maintain"
      ]
    },
    "apply_request_actor_repository_role": {
      "type": [
        "string",
        "null"
      ]
    },
    "preflight_validation_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "preflight_result_hash": {
      "$ref": "#/$defs/sha256"
    },
    "preflight_artifact": {
      "$ref": "#/$defs/artifact_provenance"
    },
    "checkout_performed": {
      "type": "boolean"
    },
    "checkout_sha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$"
    },
    "detached_head": {
      "type": "boolean"
    },
    "credentials_persisted": {
      "type": "boolean"
    },
    "patch_file_hash": {
      "$ref": "#/$defs/sha256"
    },
    "git_apply_check": {
      "$ref": "#/$defs/check_result"
    },
    "git_apply": {
      "$ref": "#/$defs/check_result"
    },
    "expected_changed_files": {
      "$ref": "#/$defs/path_array"
    },
    "resulting_file_hashes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "resulting_blob_sha"
        ],
        "properties": {
          "path": {
            "$ref": "#/$defs/repository_path"
          },
          "resulting_blob_sha": {
            "$ref": "#/$defs/full_sha"
          }
        }
      }
    },
    "diff_binding": {
      "$ref": "#/$defs/check_result"
    },
    "tests_planned": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sandbox_cleanup": {
      "$ref": "#/$defs/check_result"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "PRECHECK_PASSED"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "phase": {
            "const": "PREFLIGHT"
          },
          "failure_class": {
            "const": null
          },
          "failure_code": {
            "const": null
          },
          "patch_check": {
            "properties": {
              "status": {
                "const": "SKIPPED"
              }
            },
            "required": [
              "status"
            ]
          },
          "patch_apply": {
            "properties": {
              "status": {
                "const": "SKIPPED"
              }
            },
            "required": [
              "status"
            ]
          },
          "protected_path_check": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "blob_sha_check": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "patch_metadata_check": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "tests_requested": {
            "items": {
              "properties": {
                "requested": {
                  "const": true
                },
                "executed": {
                  "const": false
                },
                "status": {
                  "const": "SKIPPED"
                }
              },
              "required": [
                "requested",
                "executed",
                "status"
              ]
            }
          },
          "tests_executed": {
            "maxItems": 0
          },
          "test_results": {
            "maxItems": 0
          },
          "changed_files_match_expected": {
            "const": true
          },
          "persistent_repository_modified": {
            "const": false
          },
          "sandbox_worktree_modified": {
            "const": false
          },
          "sandbox_checkout_performed": {
            "const": false
          },
          "patch_check_performed": {
            "const": false
          },
          "patch_applied": {
            "const": false
          },
          "test_execution_performed": {
            "const": false
          },
          "commit_created": {
            "const": false
          },
          "push_performed": {
            "const": false
          },
          "merge_performed": {
            "const": false
          },
          "sandbox_destroyed": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "APPLY_PASSED"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "phase": {
            "const": "SANDBOX_APPLY"
          },
          "failure_class": {
            "const": null
          },
          "failure_code": {
            "const": null
          },
          "patch_check": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "patch_apply": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "git_apply_check": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "git_apply": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "diff_binding": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "tests_executed": {
            "maxItems": 0
          },
          "test_results": {
            "maxItems": 0
          },
          "changed_files_match_expected": {
            "const": true
          },
          "persistent_repository_modified": {
            "const": false
          },
          "sandbox_checkout_performed": {
            "const": true
          },
          "checkout_performed": {
            "const": true
          },
          "patch_check_performed": {
            "const": true
          },
          "patch_applied": {
            "const": true
          },
          "test_execution_performed": {
            "const": false
          },
          "commit_created": {
            "const": false
          },
          "push_performed": {
            "const": false
          },
          "merge_performed": {
            "const": false
          },
          "sandbox_destroyed": {
            "const": true
          }
        },
        "required": [
          "apply_request_actor",
          "apply_request_actor_repository_permission",
          "preflight_validation_id",
          "preflight_result_hash",
          "preflight_artifact",
          "checkout_performed",
          "checkout_sha",
          "detached_head",
          "credentials_persisted",
          "patch_file_hash",
          "git_apply_check",
          "git_apply",
          "expected_changed_files",
          "resulting_file_hashes",
          "diff_binding",
          "tests_planned",
          "sandbox_cleanup"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "SUCCESS"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "failure_class": {
            "const": null
          },
          "failure_code": {
            "const": null
          },
          "patch_check": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "patch_apply": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "protected_path_check": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "blob_sha_check": {
            "properties": {
              "status": {
                "const": "PASS"
              }
            },
            "required": [
              "status"
            ]
          },
          "tests_requested": {
            "items": {
              "properties": {
                "requested": {
                  "const": true
                },
                "executed": {
                  "const": true
                },
                "status": {
                  "const": "PASS"
                }
              },
              "required": [
                "requested",
                "executed",
                "status"
              ]
            }
          },
          "tests_executed": {
            "items": {
              "properties": {
                "requested": {
                  "const": true
                },
                "executed": {
                  "const": true
                },
                "status": {
                  "const": "PASS"
                }
              },
              "required": [
                "requested",
                "executed",
                "status"
              ]
            }
          },
          "test_results": {
            "items": {
              "properties": {
                "requested": {
                  "const": true
                },
                "executed": {
                  "const": true
                },
                "status": {
                  "const": "PASS"
                }
              },
              "required": [
                "requested",
                "executed",
                "status"
              ]
            }
          },
          "changed_files_match_expected": {
            "const": true
          },
          "persistent_repository_modified": {
            "const": false
          },
          "commit_created": {
            "const": false
          },
          "push_performed": {
            "const": false
          },
          "merge_performed": {
            "const": false
          },
          "sandbox_destroyed": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "PATCH_REJECTED"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "failure_class": {
            "const": "PATCH_REJECTED"
          },
          "failure_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "TEST_FAILED"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "failure_class": {
            "const": "TEST_FAILED"
          },
          "failure_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "STALE"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "failure_class": {
            "const": "STALE"
          },
          "failure_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "FATAL"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "failure_class": {
            "const": "FATAL"
          },
          "failure_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
